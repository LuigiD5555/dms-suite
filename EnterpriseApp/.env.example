# Enterprise DMS environment example. Do not commit real secrets.
SECRET_KEY="replace-me-with-a-real-secret"
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,app.example.com,www.app.example.com

# Locale / region. The default remains Mexico because the seed catalog included
# in the original project is Mexican, but the app can be configured per deploy.
COUNTRY=mx
LANGUAGE_CODE=en-us
TIME_ZONE=America/Mexico_City

# Database: leave DB_ENGINE as sqlite3 for local dev, or set MySQL/MariaDB in production.
DB_ENGINE=django.db.backends.mysql
DB_APP_NAME=enterprise_dms_appdata
DB_DATA_NAME=enterprise_dms_database
DB_USER=enterprise_dms_user
DB_PASSWORD="replace-me"
DB_ROOT_PASSWORD="replace-root-password"
DB_HOST=localhost
DB_PORT=3306
ATOMIC_REQUEST=True

# Backward-compatible aliases used by the original project. Prefer the DB_*
# variables above. Uncomment these only if an old deployment script still expects
# the legacy names.
# ENGINE=django.db.backends.mysql
# APPDATA=enterprise_dms_appdata
# DB=enterprise_dms_database
# USER_DB=enterprise_dms_user
# PASSWORD=replace-me
# HOST=localhost
# PORT=3306

CSRF_TRUSTED_ORIGINS=https://app.example.com,https://www.app.example.com
CORS_ALLOWED_ORIGINS=https://app.example.com,https://www.app.example.com
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
DATA_UPLOAD_MAX_NUMBER_FIELDS=10000
LOG_LEVEL=INFO
API_PAGE_SIZE=50
